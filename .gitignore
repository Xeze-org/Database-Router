# ── Compiled binaries ─────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
db-manager
db-manager.exe
/db-router
/db-router.exe

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
.venv/
venv/
dist/
build/

# ── Rust ──────────────────────────────────────────────────────────────────────
target/
Cargo.lock

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Java ──────────────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
target/
.mvn/
mvnw
mvnw.cmd
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ── Zig ───────────────────────────────────────────────────────────────────────
zig-cache/
zig-out/

# ── C++ / CMake ───────────────────────────────────────────────────────────────
build/
out/
bin/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
compile_commands.json

# ── Go build / test artifacts ─────────────────────────────────────────────────
*.test
*.out

# ── Go module download cache (never commit — restored by go mod download) ─────
vendor/

# ── Go workspace file (local-only tool, not for sharing) ─────────────────────
go.work
go.work.sum

# ── Dependency lock checksums brought in by tools (keep go.sum, ignore rest) ──
# go.sum is intentionally NOT ignored — it must be committed

# ── Local dev tools (contain env-sourced credentials) ──────────────────────
pg.py

# ── Config with credentials ───────────────────────────────────────────────────
# config.json may contain DB passwords — use config.example.json instead
config.json

# ── TLS / mTLS certificates ───────────────────────────────────────────────────
# Private keys must NEVER be committed.
# Public certs (.crt) are safe to commit if you want to share them,
# but keeping everything out of git is the safest default.
certs/*.key
certs/*.crt
certs/*.pem
certs/*.csr
certs/*.srl
certs/*.cnf
# gen-certs.sh / gen-certs.ps1 are intentionally committed (scripts, not secrets)
!certs/gen-certs.sh
!certs/gen-certs.ps1
!certs/.gitkeep

# ── Environment / secret files ────────────────────────────────────────────────
.env
.env.*
*.env
!.env.example
secrets/

# ── Log files ─────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker local overrides ────────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.local.yml

# ── Docker data volumes (mounted paths) ───────────────────────────────────────
postgres_data/
mongodb_data/
redis_data/

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Profiling / coverage ──────────────────────────────────────────────────────
*.prof
coverage.out
coverage.html

# ── Examples ──────────────────────────────────────────────────────────────────
examples/python-mtls-test/
