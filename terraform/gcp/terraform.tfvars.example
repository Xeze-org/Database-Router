# GCP — copy to terraform.tfvars and fill in.
# Credentials come from env vars:
#   GOOGLE_CREDENTIALS (service-account JSON) + GOOGLE_PROJECT  (compute)
#   CLOUDFLARE_API_TOKEN                                        (DNS)
# Passwords are auto-generated — shown after `terraform apply`.

# IMPORTANT: restrict to your IP! Find yours: curl ifconfig.me
allowed_ips = ["YOUR_IP/32"]

# DNS (managed in Cloudflare)
domain          = "0.xeze.org"
subdomain       = "db"
cloudflare_zone = "xeze.org"

# Compute (optional overrides) — note: region is the GCP *zone*
# region        = "us-central1-a"
# instance_size = "e2-small"
# image         = "debian-cloud/debian-12"
