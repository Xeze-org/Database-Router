# Build-context excludes for the deployer image (context = repo root).

# Terraform local state & provider plugins (host-platform binaries — must
# never be baked into the Linux image; the deployer runs `terraform init`).
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.*
**/*.tfvars
**/crash.log
**/crash.*.log

# Deployer runtime state (SSH keys, fetched certs, generated state)
deployer/state/

# Credentials / local env
config.json
.env
*.env

# Go build outputs
*.exe
*.exe~
db-manager
db-router
vendor/

# VCS / editor / OS
.git/
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
