{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/venv/**",
    "**/vendor/**"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2
}
