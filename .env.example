# ==============================================================================
# NOTE: THIS FILE IS FOR LOCAL TESTING ONLY!
# 
# If you are deploying to the cloud using the automated deployer, DO NOT use this
# file. The deployer automatically generates all passwords via Terraform and 
# creates the .env file on the remote server for you. 
# 
# To change deployment configurations, edit the variables in `terraform/variables.tf`.
# ==============================================================================

# DB Router API credentials (used by pg.py)
DB_API_KEY=your_api_key_here
DB_PG_BASE=https://pg.yourdomain.com
DB_REDIS_BASE=https://redis.yourdomain.com
DB_MONGO_BASE=https://mongo.yourdomain.com

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your_mongodb_password_here
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=unified_db
REDIS_PASSWORD=your_redis_password_here
MONGO_INITDB_ROOT_DATABASE=xeze_test